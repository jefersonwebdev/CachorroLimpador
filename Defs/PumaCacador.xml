<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ========================= -->
  <!-- PUMA CAÇADOR -->
  <!-- ========================= -->

  <ThingDef ParentName="AnimalThingBase">
    <defName>PumaCacador</defName>
    <label>puma caçador</label>
    <description>Uma variação geneticamente modificada do puma, treinada para caçar pequenos animais selvagens dentro da área permitida da colônia.</description>

    <statBases>
      <MoveSpeed>5.2</MoveSpeed>
      <MarketValue>950</MarketValue>
      <Wildness>0.15</Wildness>
      <FilthRate>3</FilthRate>
    </statBases>

    <race>
      <body>QuadrupedAnimalWithPawsAndTail</body>
      <baseBodySize>0.85</baseBodySize>
      <baseHungerRate>0.45</baseHungerRate>
      <baseHealthScale>1.0</baseHealthScale>

      <!-- Carnívoro -->
      <foodType>CarnivoreAnimal</foodType>

      <!-- Animal domesticável/inteligente -->
      <trainability>Advanced</trainability>
      <petness>0.7</petness>
      <hasGenders>true</hasGenders>
      <lifeExpectancy>18</lifeExpectancy>

      <!-- Predador -->
      <predator>true</predator>
      <maxPreyBodySize>0.45</maxPreyBodySize>

      <lifeStageAges>
        <li>
          <def>AnimalBaby</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>AnimalJuvenile</def>
          <minAge>0.25</minAge>
        </li>
        <li>
          <def>AnimalAdult</def>
          <minAge>2.0</minAge>
        </li>
      </lifeStageAges>

      <soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
    </race>

    <tools>
      <li>
        <label>garras</label>
        <capacities>
          <li>Scratch</li>
        </capacities>
        <power>11</power>
        <cooldownTime>1.8</cooldownTime>
        <linkedBodyPartsGroup>FrontLeftPaw</linkedBodyPartsGroup>
      </li>

      <li>
        <label>garras</label>
        <capacities>
          <li>Scratch</li>
        </capacities>
        <power>11</power>
        <cooldownTime>1.8</cooldownTime>
        <linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
      </li>

      <li>
        <label>mordida</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>14</power>
        <cooldownTime>2.2</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
      </li>
    </tools>

    <comps>
        <li Class="BioEngenharia.CompProperties_AutoHunter">
            <huntRadius>50</huntRadius>
            <ticksBetweenScan>60</ticksBetweenScan>
            <maxPreyBodySize>0.6</maxPreyBodySize>
        </li>
    </comps>

  </ThingDef>


  <!-- ========================= -->
  <!-- SPAWN PAWN -->
  <!-- ========================= -->

  <PawnKindDef ParentName="AnimalKindBase">
    <defName>PumaCacador</defName>
    <label>puma caçador</label>
    <race>PumaCacador</race>
    <combatPower>120</combatPower>

    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Animal/Cougar/Cougar</texPath>
          <drawSize>0.8</drawSize>
        </bodyGraphicData>
      </li>

      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Animal/Cougar/Cougar</texPath>
          <drawSize>1.0</drawSize>
        </bodyGraphicData>
      </li>

      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Animal/Cougar/Cougar</texPath>
          <drawSize>2.0</drawSize>
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

</Defs>